# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# RunPod — required for pod orchestration
# See documents/references/provider-config.md for how to obtain each.
RUNPOD_API_KEY=
RUNPOD_SSH_PRIVATE_KEY=
RUNPOD_REGISTRY_AUTH_ID=

# Optional: cap on concurrent cold-start provisions (default 5)
# MAX_CONCURRENT_PROVISIONS=5

# Baked-image provisioning (Workstream 3). Skips the ~3 min ssh setup/download
# path by using a pre-built GHCR image + pre-populated network volume.
# FLUX_PROVISION_MODE=baked
# FLUX_IMAGE=ghcr.io/donpinkus/kiki-flux-klein:sha-...
# RUNPOD_GHCR_AUTH_ID=...
# NETWORK_VOLUMES_BY_DC={"EUR-NO-1":"49n6i3twuw","EU-RO-1":"xbiu29htvu","EU-CZ-1":"hhmat30tzx","US-IL-1":"59plfch67d","US-NC-1":"5vz7ubospw"}

# Cost monitoring (Workstream 4). OPS_API_KEY gates /v1/ops/* endpoints.
# OPS_API_KEY=<openssl rand -hex 32>
# COST_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# COST_ALERT_MAX_ACTIVE_PODS=50
# COST_ALERT_MAX_24H_SPEND=200
# COST_ALERT_MAX_MONTHLY_SPEND=5000
# COST_ALERT_MAX_POD_AGE_SECONDS=3600
# COST_ALERT_COOLDOWN_SECONDS=1800
# COST_MONITOR_INTERVAL_MS=300000
