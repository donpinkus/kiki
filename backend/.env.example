# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── REQUIRED — backend won't start without these ─────────────────────────

# RunPod (orchestrator needs this to create/query/terminate pods).
# See documents/references/provider-config.md for how to obtain each.
RUNPOD_API_KEY=

# JWT signing — both required, both must be ≥32 bytes, must differ.
# Generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Apple Sign-In audience — your iOS bundle id (e.g. com.donpinkus.kiki).
APPLE_BUNDLE_ID=

# ─── Pod-volume maps — required if you want pods to actually serve ────────
# Pods boot from stock runpod/pytorch and read /workspace/app/ + /workspace/venv/
# off the network volume (BASE_IMAGE is hardcoded in orchestrator.ts).
# Image-pod (RTX 5090) volumes — FLUX.2-klein weights.
NETWORK_VOLUMES_BY_DC={"EUR-NO-1":"49n6i3twuw","EU-RO-1":"xbiu29htvu","EU-CZ-1":"hhmat30tzx","US-IL-1":"59plfch67d","US-NC-1":"5vz7ubospw"}
# Video-pod (H100 SXM 80GB) volumes — LTX-2.3 + Gemma weights. Required only
# if VIDEO_POD_ENABLED=true (otherwise the orchestrator won't try to use them).
NETWORK_VOLUMES_BY_DC_VIDEO={"US-CA-2":"4iq4uchi49","US-TX-3":"bhqphgrfen","EU-NL-1":"l83rmkz50d","EUR-IS-3":"m4ac7szq80","US-MO-1":"qvm9zwa2b8","US-NE-1":"92a53hbwc1"}

# ─── Production runtime gates ─────────────────────────────────────────────

# Reject WebSocket connections that don't carry a valid Bearer JWT. Set to
# `false` for local dev only; production must always be `true`.
AUTH_REQUIRED=true

# Allow on-demand fallback when spot capacity is exhausted. Off = spot only.
ONDEMAND_FALLBACK_ENABLED=true

# Provision a video pod (LTX-2.3) alongside the image pod when the iPad
# requests it. Off = image-only sessions.
VIDEO_POD_ENABLED=true

# Redis connection string for session registry (survives backend deploys).
# Local dev: leave unset to fall back to in-memory; production: required.
# REDIS_URL=redis://...

# ─── Rollback-only (pre-2026-04-23 GHCR custom-image flow) ────────────────
# Leave unset for normal operation. Setting these has no effect unless
# orchestrator.ts is reverted to the pre-cutover commit (332bcad^). See
# documents/references/pod-operations.md Task 10.
# FLUX_IMAGE=ghcr.io/donpinkus/kiki-flux-klein:latest
# RUNPOD_GHCR_AUTH_ID=

# ─── Optional tuning ──────────────────────────────────────────────────────

# Cap on concurrent cold-start provisions (default 5).
# MAX_CONCURRENT_PROVISIONS=5

# PostHog analytics (used by orchestrator for pod.* events; optional).
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Cost monitoring (Workstream 4). OPS_API_KEY gates /v1/ops/* endpoints.
# OPS_API_KEY=<openssl rand -hex 32>
# COST_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# COST_ALERT_MAX_ACTIVE_PODS=50
# COST_ALERT_MAX_24H_SPEND=200
# COST_ALERT_MAX_MONTHLY_SPEND=5000
# COST_ALERT_MAX_POD_AGE_SECONDS=3600
# COST_ALERT_COOLDOWN_SECONDS=1800
# COST_MONITOR_INTERVAL_MS=300000
